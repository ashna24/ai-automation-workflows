    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json.output || \"\";\n\n\nconst categoryMatch = text.match(/Category[:\\s\"']+(.*?)(?=[\"']?[\\s,]*$|\\n)/i);\nconst priorityMatch = text.match(/Priority[:\\s\"']+(.*?)(?=[\"']?[\\s,]*$|\\n)/i);\n\n\nconst clean = (str) => {\n  if (!str) return \"Not Found\";\n \n  return str.replace(/^[:\\s\"']+|[:\\s\"',]+$/g, '').trim();\n};\n\nreturn {\n  ...$json,\n  category: clean(categoryMatch ? categoryMatch[1] : null),\n  priority: clean(priorityMatch ? priorityMatch[1] : null),\n  raw_text_length: text.length \n};"
      },
