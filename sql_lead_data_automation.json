      {
        "parameters": {
          "jsCode": "// 1. Get the raw text from the AI Agent\nconst rawOutput = items[0].json.output;\n\n// 2. Use a Regex to find the JSON block if the AI added conversational text\nconst jsonMatch = rawOutput.match(/\\{[\\s\\S]*\\}/);\n\nif (jsonMatch) {\n  try {\n    // 3. Parse the cleaned string into a JSON object\n    const cleanedData = JSON.parse(jsonMatch[0]);\n\n    // 4. Return the structured data for the SQL node\n    return [{ \n      json: {\n        entities: cleanedData.entities || \"N/A\",\n        score: parseInt(cleanedData.score) || 0,\n      }\n    }];\n  } catch (error) {\n    // Fallback if parsing fails\n    return [{ json: { entities: \"Error\", score: 0, } }];\n  }\n}\n\nreturn [{ json: { entities: \"Not Found\", score: 0 } }];"
        },
